rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Proof photos ────────────────────────────────────────────────────────
    // Path: proof/{teamId}/{date}/{uid}_{activityId}.jpg
    // - Only authenticated users may upload their own proof (filename must be uid_activityId.jpg).
    // - File must be ≤ 10 MB and typed as image/jpeg.
    // - Deploy after editing: firebase deploy --only storage
    match /proof/{teamId}/{date}/{filename} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && filename.matches('^' + request.auth.uid + '_[^/]+\\.jpg$')
                    && request.resource.size  < 10 * 1024 * 1024
                    && request.resource.contentType == 'image/jpeg';
      // Allow the owner to overwrite their own proof photo (needed for rejected-submission retakes)
      allow update: if request.auth != null
                    && filename.matches('^' + request.auth.uid + '_[^/]+\\.jpg$')
                    && request.resource.size  < 10 * 1024 * 1024
                    && request.resource.contentType == 'image/jpeg';
      allow delete: if false;
    }

  }
}
