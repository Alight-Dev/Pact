// Copy this file to Development.xcconfig and set your Apple Developer Team ID.
// Find it in Xcode: Signing & Capabilities → Team, or at https://developer.apple.com/account
//
// Only DEVELOPMENT_TEAM is per-developer. PRODUCT_BUNDLE_IDENTIFIER is shared across
// the team and is set to cmc.Pact in project.pbxproj — do not override it here.

DEVELOPMENT_TEAM = YOUR_TEAM_ID_HERE
